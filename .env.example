# Anthropic (Chairman + Haiku agent fallback)
ANTHROPIC_API_KEY=sk-ant-...

# Groq (free Llama — default provider for the automatic trader)
GROQ_API_KEY=...
SCHEDULED_PROVIDER=groq          # "groq" (default) or "anthropic"

# Market data
FINNHUB_API_KEY=...              # news & sentiment
FMP_API_KEY=...                  # fundamentals & screener

# Database (Supabase / Railway PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Scheduling
ENABLE_SCHEDULER=true            # false on free/sleeping hosts (use the GitHub Actions cron)
CRON_SECRET=                     # if set, /api/run-committee requires X-Cron-Secret
DAILY_BUDGET_USD=1.25            # hard cap on daily Claude spend
COMMITTEE_MAX_TICKERS=30         # tickers screened per session

# App
FRONTEND_URL=https://your-app.vercel.app
